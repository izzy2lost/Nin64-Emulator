<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Top bar: logo (center) + settings icon (end) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Balancing spacer so logo stays centered -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@mipmap/ic_launcher_foreground"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings" />
    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/dividerHorizontal" />

    <!-- Content area with pull-to-refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- No folder picked: single centered button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/pickFolderButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="@string/open_games_folder"
                android:visibility="visible" />

            <!-- Folder picked: game list -->
            <ListView
                android:id="@+id/romListView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="?attr/dividerHorizontal"
                android:dividerHeight="1dp"
                android:scrollbars="vertical"
                android:fastScrollEnabled="true"
                android:visibility="gone" />

            <!-- Folder picked but no games found -->
            <TextView
                android:id="@+id/emptyRomListText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="32dp"
                android:text="@string/no_games_in_folder"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:visibility="gone" />

        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Hidden compat views required by existing code -->
    <TextView android:id="@+id/statusText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:text="@string/initial_status" />
    <TextView android:id="@+id/configPathText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/romFolderText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/gamesHeaderText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:text="@string/games_header" />
    <ImageView android:id="@+id/framePreviewImage" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:contentDescription="@string/frame_preview_label" />
    <TextView android:id="@+id/framePreviewLabel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:text="@string/frame_preview_label" />
    <TextView android:id="@+id/statusLabel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:text="@string/status_label" />
    <TextView android:id="@+id/configPathLabel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:text="@string/config_path_label" />

</LinearLayout>
