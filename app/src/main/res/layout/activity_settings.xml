<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/navigate_up" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings"
            android:textColor="?attr/colorOnSurface"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingStart="8dp" />
    </LinearLayout>

    <!-- Settings content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Game Folder section: blue -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_blue"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/game_folder"
                    android:textColor="@color/brand_blue"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/folderPathText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/game_folder_not_set"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/changeFolderButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/change_folder"
                    android:textColor="@color/brand_blue"
                    app:strokeColor="@color/brand_blue"
                    app:rippleColor="@color/brand_blue"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />
            </LinearLayout>

            <!-- Display section: yellow -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_yellow"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_display_header"
                    android:textColor="@color/brand_yellow"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/settings_aspect_label"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/aspectSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/settings_resolution_label"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/resolutionSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Controls section: green -->
            <LinearLayout
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_green"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_controls_header"
                    android:textColor="@color/brand_green"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editTouchLayoutButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/controls_edit_touch_layout"
                    android:textColor="@color/brand_green"
                    app:strokeColor="@color/brand_green"
                    app:rippleColor="@color/brand_green" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editControllerMappingButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/controls_edit_controller_mapping"
                    android:textColor="@color/brand_green"
                    app:strokeColor="@color/brand_green"
                    app:rippleColor="@color/brand_green" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resetControlsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/controls_reset_controls"
                    android:textColor="@color/brand_red"
                    app:strokeColor="@color/brand_red"
                    app:rippleColor="@color/brand_red" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
